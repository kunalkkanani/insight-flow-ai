# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000

# ── Claude model (optional – defaults to claude-sonnet-4-6) ───────────────────
CLAUDE_MODEL=claude-sonnet-4-6

# ── DuckDB tuning ─────────────────────────────────────────────────────────────
MAX_QUERY_ROWS=50000
SAMPLE_THRESHOLD_ROWS=500000
LARGE_DATASET_THRESHOLD_ROWS=5000000
DEFAULT_SAMPLE_ROWS=100000

# ── File uploads ──────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=500
UPLOAD_DIR=/tmp/insight_flow_uploads
